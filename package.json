{
  "name": "AIchatHub",
  "version": "1.2.1",
  "description": "AI Chat Hub - 多平台 AI 助手聚合客户端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "icon": "node scripts/make-icon.js"
  },
  "keywords": [],
  "author": "AI Chat Hub",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.aichathub.app",
    "productName": "AI Chat Hub",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "floatball.html",
      "floatball-preload.js",
      "fonts/**/*",
      "svg/**/*",
      "assets/logo-32.png",
      "assets/logo-256.png"
    ],
    "extraResources": [
      {
        "from": "fonts",
        "to": "fonts"
      }
    ],
    "win": {
      "icon": "assets/logo-256.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Chat Hub",
      "installerLanguages": ["zh_CN", "en_US"],
      "language": "2052",
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  }
}
